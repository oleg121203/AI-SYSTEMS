{
  "name": "Python & Node.js Development",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/rust:1": {},
    "ghcr.io/devcontainers/features/go:1": {}
  },
  "runArgs": ["--add-host=host.docker.internal:host-gateway", "--network=host"],
  "containerEnv": {
    "OLLAMA_HOST": "http://localhost:11434",
    "OLLAMA_API": "http://localhost:11434",
    "TZ": "Europe/Kyiv"
  },
  "mounts": [
    "source=my-app-data,target=/data,type=volume",
    "source=${localWorkspaceFolder},target=/home/dev/vscode/AI-SYSTEMS,type=bind,consistency=cached"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.black-formatter",
        "ms-python.flake8",
        "ms-python.isort",
        "ms-python.vscode-pylance",
        "njpwerner.autodocstring",
        "ms-toolsai.jupyter",
        "ms-python.debugpy",
        "ms-python.pytest",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "vscjava.vscode-java-pack",
        "redhat.java",
        "vscjava.vscode-java-debug",
        "vscjava.vscode-maven",
        "streetsidesoftware.code-spell-checker",
        "ms-vscode-remote.remote-containers",
        "eamodio.gitlens",
        "ms-azuretools.vscode-docker",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "batisteo.vscode-django",
        "openai.openai-chatgpt-adhoc",
        "donjayamanne.python-environment-manager",
        "donjayamanne.python-extension-manager",
        "foxundermoon.shell-format",
        "timonwong.shellcheck",
        "yzhang.markdown-all-in-one",
        "redhat.vscode-yaml",
        "golang.go",
        "rust-lang.rust-analyzer",
        "editorconfig.editorconfig",
        "DavidAnson.vscode-markdownlint",
        "SonarSource.sonarlint-vscode"
      ]
    }
  },
  "forwardPorts": [9000, 3000, 7860, 11434],
  "portsAttributes": {
    "9000": {
      "label": "Hello Remote World",
      "onAutoForward": "notify"
    },
    "3000": {
      "label": "Node.js Application",
      "onAutoForward": "notify"
    },
    "7860": {
      "label": "Application Port",
      "onAutoForward": "notify"
    },
    "11434": {
      "label": "Ollama API",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y shfmt shellcheck && pip install --upgrade pip && pip install flake8==7.1.1 black==24.8.0 isort==5.13.2 pytest==8.3.3 httpx==0.27.2 pydantic==2.9.2 && if [ -f \"${containerWorkspaceFolder}/package.json\" ]; then cd \"${containerWorkspaceFolder}\" && npm install; fi && if [ -f \"${containerWorkspaceFolder}/Cargo.toml\" ]; then cargo build; fi && git config --global user.name \"Oleg Kizyma\" && git config --global user.email \"oleg1203@gmail.com\" && echo 'Setup completed successfully'",
  "workspaceFolder": "/home/dev/vscode/AI-SYSTEMS"
}
