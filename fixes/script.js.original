/**
 * Fetches models for a given provider and populates a model select dropdown.
 * Also handles selection of a model and "Default model" option for fallbacks.
 * @param {string} providerName - The name of the provider.
 * @param {HTMLSelectElement} modelSelectElement - The <select> element for models.
 * @param {string|null} selectedModelName - The name of the model to select by default. Can be "" for fallback default.
 */
async function populateModelsForProvider(
  providerName,
  modelSelectElement,
  selectedModelName
) {
  if (!modelSelectElement) {
    console.error(
      "populateModelsForProvider: modelSelectElement is null for provider:",
      providerName
    );
    return;
  }
  if (!providerName) {
    modelSelectElement.innerHTML =
      '<option value="">Select a provider first</option>';
    return;
  }
  modelSelectElement.innerHTML = '<option value="">Loading models...</option>';

  let models = []; // Expect array of model name strings
  // window.providerModels is a global cache: { providerName: [modelName1, modelName2, ...] }
  if (window.providerModels && window.providerModels[providerName]) {
    models = window.providerModels[providerName];
  } else {
    try {
      const response = await fetch(
        `/provider_models?provider=${encodeURIComponent(providerName)}`
      );
      if (!response.ok)
        throw new Error(
          `HTTP error fetching models for ${providerName}: ${response.status}`
        );
      const data = await response.json();
      models = data.models || []; // data.models should be an array of strings
      if (!window.providerModels) window.providerModels = {};
      window.providerModels[providerName] = models;
    } catch (error) {
      console.error(
        `Error in populateModelsForProvider for ${providerName}:`,
        error
      );
      modelSelectElement.innerHTML =
        '<option value="">Error loading models</option>';
      return;
    }
  }

  modelSelectElement.innerHTML = ""; // Clear loading/error

  let isFallbackModelSelect = modelSelectElement.id.includes("-fallback-");

  if (isFallbackModelSelect) {
    const defaultOption = document.createElement("option");
    defaultOption.value = ""; // Empty value signifies provider's default model
    defaultOption.textContent = "Default (uses provider's default)";
    modelSelectElement.appendChild(defaultOption);
  }

  if (models.length === 0) {
    if (!isFallbackModelSelect) {
      // Only add "No models" if not a fallback (which has "Default")
      const option = document.createElement("option");
      option.value = "";
      option.textContent = "No models available";
      modelSelectElement.appendChild(option);
    }
  } else {
    models.forEach((modelName) => {
      const option = document.createElement("option");
      option.value = modelName;
      option.textContent = modelName;
      modelSelectElement.appendChild(option);
    });
  }

  // Set selection
  if (selectedModelName !== null && selectedModelName !== undefined) {
    if (
      modelSelectElement.querySelector(`option[value="${selectedModelName}"]`)
    ) {
      modelSelectElement.value = selectedModelName;
    } else if (isFallbackModelSelect) {
      // For fallbacks, if specified model not found, stick to "Default"
      modelSelectElement.value = "";
    } else if (models.length > 0) {
      // For main provider, if specified model not found, select first available
      modelSelectElement.value = models[0];
    }
  } else if (!isFallbackModelSelect && models.length > 0) {
    modelSelectElement.value = models[0]; // No specific model for main, select first
  } else if (isFallbackModelSelect) {
    modelSelectElement.value = ""; // No specific model for fallback, ensure "Default" is selected
  }

  // Final check: if a main select still has no value but has models, pick the first actual model.
  if (
    !modelSelectElement.value &&
    !isFallbackModelSelect &&
    modelSelectElement.options.length > 0
  ) {
    for (let i = 0; i < modelSelectElement.options.length; i++) {
      if (modelSelectElement.options[i].value !== "") {
        modelSelectElement.value = modelSelectElement.options[i].value;
        break;
      }
    }
  }
}

/**
 * Determines the active provider and model for a component based on its specific provider list.
 * @param {object} componentOriginalConfig - The original config { provider, model, fallbacks }.
 * @param {string[]|null} componentSpecificProvidersList - Array of allowed provider names for this component.
 * @param {object} globalProvidersDefinitions - Global map of provider definitions (from config.json "providers").
 * @returns {object} - { provider, model, fallbacks } for the component.
 */
function determineActiveProviderAndModel(
  componentOriginalConfig,
  componentSpecificProvidersList,
  globalProvidersDefinitions
) {
  let activeProvider = componentOriginalConfig.provider;
  let activeModel = componentOriginalConfig.model;

  const specificList =
    componentSpecificProvidersList &&
    Array.isArray(componentSpecificProvidersList) &&
    componentSpecificProvidersList.length > 0
      ? componentSpecificProvidersList
      : null;

  if (specificList) {
    const newProviderCandidate = specificList[0];
    activeProvider = newProviderCandidate; // Prioritize the first from the specific list

    if (
      globalProvidersDefinitions &&
      globalProvidersDefinitions[activeProvider] &&
      globalProvidersDefinitions[activeProvider].model
    ) {
      activeModel = globalProvidersDefinitions[activeProvider].model;
    } else {
      console.warn(
        `determineActiveProviderAndModel: Model for new active provider '${activeProvider}' not found in global definitions (path: providers.${activeProvider}.model). Original model was '${componentOriginalConfig.model}'. Setting model to empty.`
      );
      activeModel = ""; // Set to empty; UI should then select first available or prompt.
    }
  }

  return {
    provider: activeProvider,
    model: activeModel,
    fallbacks: componentOriginalConfig.fallbacks || [],
  };
}

/**
 * Initializes the provider configuration UI based on window.currentConfig.
 */
async function initProviderConfig() {
  // This is the function starting around line 5200
  if (
    !window.currentConfig ||
    !window.currentConfig.ai_config ||
    !window.currentConfig.providers // This is the global provider definition map
  ) {
    console.error(
      "Current config (window.currentConfig), ai_config, or global providers definitions not found. Cannot initialize provider UI."
    );
    return;
  }
  const aiConfig = window.currentConfig.ai_config; // This is like { ai1: {...}, ai2: {...}, ... }
  const globalAvailableProviderNames = Object.keys(
    window.currentConfig.providers // e.g., ["ollama", "codestral", "gemini", ...]
  );
  const globalProvidersDefinitions = window.currentConfig.providers; // Full definitions

  // AI1
  if (aiConfig.ai1) {
    const componentSpecificList =
      aiConfig.ai1.providers && Array.isArray(aiConfig.ai1.providers)
        ? aiConfig.ai1.providers
        : null;
    // aiConfig.ai1 is { provider, model, fallbacks, providers (list) }
    const agentData = determineActiveProviderAndModel(
      aiConfig.ai1,
      componentSpecificList,
      globalProvidersDefinitions
    );
    setupAgentUI(
      "ai1",
      agentData,
      globalAvailableProviderNames,
      componentSpecificList
    );
  }

  // AI2 Roles
  if (aiConfig.ai2) {
    const roles = ["executor", "tester", "documenter"];
    roles.forEach((role) => {
      if (aiConfig.ai2[role]) {
        // aiConfig.ai2[role] is { provider, model, fallbacks }
        const roleOriginalConfig = aiConfig.ai2[role];
        let componentSpecificList = null;
        if (
          aiConfig.ai2.providers &&
          aiConfig.ai2.providers[role] &&
          Array.isArray(aiConfig.ai2.providers[role])
        ) {
          componentSpecificList = aiConfig.ai2.providers[role];
        }
        const agentData = determineActiveProviderAndModel(
          roleOriginalConfig,
          componentSpecificList,
          globalProvidersDefinitions
        );
        setupAgentUI(
          `ai2-${role}`,
          agentData,
          globalAvailableProviderNames,
          componentSpecificList
        );
      }
    });
  }

  // AI3
  if (aiConfig.ai3) {
    // AI3 Main
    const ai3MainOriginalConfig = {
      provider: aiConfig.ai3.provider,
      model: aiConfig.ai3.model,
      fallbacks: aiConfig.ai3.fallbacks || [],
    };
    const ai3MainSpecificList =
      aiConfig.ai3.providers && Array.isArray(aiConfig.ai3.providers)
        ? aiConfig.ai3.providers
        : null;
    const ai3MainAgentData = determineActiveProviderAndModel(
      ai3MainOriginalConfig,
      ai3MainSpecificList,
      globalProvidersDefinitions
    );
    setupAgentUI(
      "ai3-main",
      ai3MainAgentData,
      globalAvailableProviderNames,
      ai3MainSpecificList
    );

    // AI3 Structure
    if (aiConfig.ai3.structure_provider !== undefined) {
      const ai3StructureOriginalConfig = {
        provider: aiConfig.ai3.structure_provider,
        model: aiConfig.ai3.structure_model,
        fallbacks: aiConfig.ai3.structure_fallbacks || [],
      };
      const ai3StructureSpecificList =
        aiConfig.ai3.structure_providers &&
        Array.isArray(aiConfig.ai3.structure_providers)
          ? aiConfig.ai3.structure_providers
          : null;
      const ai3StructureAgentData = determineActiveProviderAndModel(
        ai3StructureOriginalConfig,
        ai3StructureSpecificList,
        globalProvidersDefinitions
      );
      setupAgentUI(
        "ai3-structure",
        ai3StructureAgentData,
        globalAvailableProviderNames,
        ai3StructureSpecificList
      );
    }
  }
  console.log("Provider configuration UI initialized with new logic.");
}

// Ensure this new initProviderConfig replaces the old one.
// The DOMContentLoaded listener at the very end of the file calls initProviderConfig.

// Now, update addFallbackProvider and setupAgentUI to use populateModelsForProvider

/**
 * Adds a new fallback provider UI section.
 * @param {string} agentKey - The agent key (e.g., 'ai1', 'ai2-executor').
 * @param {HTMLElement} fallbacksContainerElement - The container to add the fallback UI to.
 * @param {string[]} availableProviderNames - List of provider names for the dropdown.
 * @param {object|null} fbConfig - Fallback configuration { provider, model } to pre-fill.
 */
function addFallbackProvider( // This is the function around line 4955
  agentKey,
  fallbacksContainerElement,
  availableProviderNames,
  fbConfig = null
) {
  const fallbackId = `fallback-${agentKey}-${Date.now()}-${Math.random()
    .toString(36)
    .substring(2, 7)}`;
  const fallbackDiv = document.createElement("div");
  fallbackDiv.className = "fallback-provider-item"; // Ensure this class matches CSS if any
  fallbackDiv.id = fallbackId;
  // Basic styling, can be enhanced with CSS classes
  fallbackDiv.style.display = "flex";
  fallbackDiv.style.alignItems = "center";
  fallbackDiv.style.marginBottom = "5px";
  fallbackDiv.style.padding = "5px";
  fallbackDiv.style.border = "1px dashed #ccc";

  const providerSelect = document.createElement("select");
  providerSelect.className = "fallback-provider-select"; // For styling/selection
  providerSelect.style.marginRight = "5px";
  populateProviderDropdown(
    // Assuming populateProviderDropdown (line 4925) is suitable
    providerSelect,
    availableProviderNames,
    fbConfig
      ? fbConfig.provider
      : availableProviderNames.length > 0
      ? availableProviderNames[0]
      : null // Pre-select first if new
  );

  const modelSelect = document.createElement("select");
  modelSelect.className = "fallback-model-select"; // For styling/selection
  modelSelect.style.marginRight = "10px";

  // Initial population of models
  const initialProviderForModels = providerSelect.value;
  if (initialProviderForModels) {
    populateModelsForProvider(
      initialProviderForModels,
      modelSelect,
      fbConfig ? fbConfig.model : "" // "" for default model
    );
  } else {
    modelSelect.innerHTML = '<option value="">Select provider</option>';
  }

  providerSelect.addEventListener("change", () => {
    populateModelsForProvider(providerSelect.value, modelSelect, ""); // On change, aim for default model
  });

  const removeButton = document.createElement("button");
  removeButton.textContent = "Remove"; // Simpler text
  removeButton.className = "remove-fallback-button"; // For styling
  removeButton.style.marginLeft = "auto"; // Push to the right
  removeButton.onclick = () => {
    fallbackDiv.remove();
    // Optionally, trigger a save or update state if needed immediately
  };

  const labelProvider = document.createElement("span");
  labelProvider.textContent = "Fallback: ";
  labelProvider.style.marginRight = "3px";

  const labelModel = document.createElement("span");
  labelModel.textContent = "Model: ";
  labelModel.style.marginRight = "3px";
  labelModel.style.marginLeft = "5px";

  fallbackDiv.appendChild(labelProvider);
  fallbackDiv.appendChild(providerSelect);
  fallbackDiv.appendChild(labelModel);
  fallbackDiv.appendChild(modelSelect);
  fallbackDiv.appendChild(removeButton);
  fallbacksContainerElement.appendChild(fallbackDiv);
}

/**
 * Sets up the UI for a specific AI agent/component based on config.
 * @param {string} agentKeyPrefix - Prefix for element IDs (e.g., 'ai1', 'ai2-executor').
 * @param {object} agentData - Config data for the agent { provider, model, fallbacks }.
 * @param {string[]} globalAvailableProviderNames - Global list of provider names.
 * @param {string[]|null} specificAvailableProviderNames - Agent-specific list of provider names.
 */
function setupAgentUI( // This is the function around line 5045
  agentKeyPrefix,
  agentData, // { provider, model, fallbacks }
  globalAvailableProviderNames,
  specificAvailableProviderNames = null
) {
  const providerSelect = document.getElementById(
    `${agentKeyPrefix}-provider-select`
  );
  const modelSelect = document.getElementById(`${agentKeyPrefix}-model-select`);
  const fallbacksContainer = document.getElementById(
    `${agentKeyPrefix}-fallbacks-container`
  );
  const addFallbackButton = document.getElementById(
    `add-fallback-${agentKeyPrefix}`
  );

  if (!providerSelect || !modelSelect || !fallbacksContainer) {
    console.warn(
      `UI elements for ${agentKeyPrefix} not found. Provider: ${!!providerSelect}, Model: ${!!modelSelect}, FallbacksContainer: ${!!fallbacksContainer}. Skipping setup.`
    );
    return;
  }

  let providersForMainDropdown =
    specificAvailableProviderNames && specificAvailableProviderNames.length > 0
      ? [...specificAvailableProviderNames]
      : [...globalAvailableProviderNames];

  // Ensure the agentData.provider (determined by determineActiveProviderAndModel) is in the list
  if (
    agentData.provider &&
    !providersForMainDropdown.includes(agentData.provider)
  ) {
    providersForMainDropdown.push(agentData.provider);
    console.warn(
      `setupAgentUI for ${agentKeyPrefix}: Active provider '${agentData.provider}' was not in its initial list. Added it.`
    );
  }
  if (providersForMainDropdown.length === 0 && agentData.provider) {
    // Case: no specific/global, but agentData has one
    providersForMainDropdown.push(agentData.provider);
  }

  populateProviderDropdown(
    providerSelect,
    providersForMainDropdown,
    agentData.provider
  );

  // Fetch models for the (now correctly) selected main provider
  if (providerSelect.value) {
    // providerSelect.value should be agentData.provider if list wasn't empty
    populateModelsForProvider(
      providerSelect.value,
      modelSelect,
      agentData.model
    );
  } else {
    // If providerSelect.value is empty (e.g. providersForMainDropdown was empty)
    modelSelect.innerHTML = '<option value="">No providers available</option>';
  }

  providerSelect.addEventListener("change", () => {
    if (providerSelect.value) {
      populateModelsForProvider(providerSelect.value, modelSelect, null); // Fetch models, select first/default
    } else {
      modelSelect.innerHTML = '<option value="">Select a provider</option>';
    }
  });

  fallbacksContainer.innerHTML = ""; // Clear existing fallbacks UI

  // Determine the list of providers to be used for NEW fallbacks for this agent
  const baseProvidersForNewFallbacks =
    specificAvailableProviderNames && specificAvailableProviderNames.length > 0
      ? [...specificAvailableProviderNames]
      : [...globalAvailableProviderNames];

  if (agentData.fallbacks && Array.isArray(agentData.fallbacks)) {
    agentData.fallbacks.forEach((fbConfig) => {
      // fbConfig is { provider, model }
      // For each existing fallback, its dropdown should also contain its configured provider
      // The 'availableProviderNames' for this specific fallback's dropdown:
      let fallbackSpecificDropdownOptions = [...baseProvidersForNewFallbacks];
      if (
        fbConfig.provider &&
        !fallbackSpecificDropdownOptions.includes(fbConfig.provider)
      ) {
        fallbackSpecificDropdownOptions.push(fbConfig.provider);
      }
      addFallbackProvider(
        agentKeyPrefix,
        fallbacksContainer,
        fallbackSpecificDropdownOptions,
        fbConfig
      );
    });
  }

  if (addFallbackButton) {
    addFallbackButton.onclick = (event) => {
      event.preventDefault();
      addFallbackProvider(
        agentKeyPrefix,
        fallbacksContainer,
        baseProvidersForNewFallbacks, // Use the agent's base list for new fallbacks
        null // No pre-filled config for a new fallback
      );
    };
  } else {
    console.warn(
      `Add fallback button #add-fallback-${agentKeyPrefix} not found.`
    );
  }
}
// ... The rest of the script, including the DOMContentLoaded that calls initProviderConfig
// Ensure populateProviderDropdown (around line 4925) is robust.
// It is: populateProviderDropdown(selectElement, providerNames, selectedProviderName)
// It correctly populates and selects. If selectedProviderName is not in providerNames,
// it selects the first from providerNames if the list is not empty. This is good.

// Global providerModels cache, should be initialized if not already
// let providerModels = {}; // This is at line 4016, so it's fine.

// The original async function fetchProviderModels(providerName) at 4018
// can remain if it's used by other parts of the system non-UI related.
// If it's only for UI, populateModelsForProvider replaces its UI role.
// For now, let's assume it might be used elsewhere.

// Final check on getComponentConfig (around line 5387)
// It uses IDs like `${componentId}-provider-select`, `${componentId}-model-select`, `${componentId}-fallbacks-container`
// And for fallbacks: item.querySelector(".fallback-provider-select"), item.querySelector(".fallback-model-select")
// This matches the classes used in the modified addFallbackProvider. This should be okay.
// The previous edit to getComponentConfig already corrected the main selector IDs.

// Initialize fallbacks for a specific component
async function initializeComponentFallbacks(aiComponent) {
  console.log(`Initializing fallbacks for ${aiComponent}`);
  const fallbacksList = document.getElementById(`${aiComponent}-fallback-list`);
  
  if (!fallbacksList) {
    console.error(`Fallback list not found for component ${aiComponent}`);
    return;
  }
  
  // Clear existing fallbacks
  fallbacksList.innerHTML = "";
  
  // Fetch the current configuration
  try {
    const response = await fetch("/providers");
    if (!response.ok) {
      throw new Error(`Failed to fetch providers: ${response.statusText}`);
    }
    
    const data = await response.json();
    if (!data || !data.current_config) {
      console.warn("No configuration data available for fallbacks");
      return;
    }
    
    // Get fallbacks based on the component type
    let fallbacks = [];
    
    if (aiComponent === "ai1" && data.current_config.ai1) {
      fallbacks = data.current_config.ai1.fallbacks || [];
    } else if (aiComponent === "ai2-executor" && 
              data.current_config.ai2 && 
              data.current_config.ai2.executor) {
      fallbacks = data.current_config.ai2.executor.fallbacks || [];
    } else if (aiComponent === "ai2-tester" && 
              data.current_config.ai2 && 
              data.current_config.ai2.tester) {
      fallbacks = data.current_config.ai2.tester.fallbacks || [];
    } else if (aiComponent === "ai2-documenter" && 
              data.current_config.ai2 && 
              data.current_config.ai2.documenter) {
      fallbacks = data.current_config.ai2.documenter.fallbacks || [];
    } else if (aiComponent === "ai3" && data.current_config.ai3) {
      fallbacks = data.current_config.ai3.fallbacks || [];
    } else if (aiComponent === "ai3-structure" && 
              data.current_config.ai3) {
      fallbacks = data.current_config.ai3.structure_fallbacks || [];
    }
    
    // Add each fallback to the UI
    for (let i = 0; i < fallbacks.length; i++) {
      const fallback = fallbacks[i];
      addFallbackToUI(aiComponent, fallback.provider, fallback.model, i);
    }
    
    console.log(`Initialized ${fallbacks.length} fallbacks for ${aiComponent}`);
    
  } catch (error) {
    console.error(`Error initializing fallbacks for ${aiComponent}:`, error);
  }
}
