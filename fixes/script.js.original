  ];
  fallbackLists.forEach((list) => {
    if (list) list.innerHTML = "";
  });

  // Always use currentConfig.ai_config for all fallbacks
  const aiConfig =
    currentConfig && currentConfig.ai_config
      ? currentConfig.ai_config
      : currentConfig;

  // AI1
  if (
