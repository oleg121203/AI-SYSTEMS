// Ensure window.currentConfig and window.currentConfig.providers are loaded before calling this.
// Example: Call this after WebSocket message with config, or on DOMContentLoaded if config is embedded.

/**
 * Populates a select dropdown with provider names.
 * @param {HTMLSelectElement} selectElement - The <select> element to populate.
 * @param {string[]} providerNames - An array of provider names.
 * @param {string|null} selectedProviderName - The name of the provider to select by default.
 */
function populateProviderDropdown(
  selectElement,
  providerNames,
  selectedProviderName
) {
  selectElement.innerHTML = ""; // Clear existing options
  providerNames.forEach((name) => {
    const option = document.createElement("option");
    option.value = name;
    option.textContent = name; // Or a more display-friendly name if available
    if (name === selectedProviderName) {
      option.selected = true;
    }
    selectElement.appendChild(option);
  });

  // If a selectedProviderName was given but not found, or none was given,
  // and the list is not empty, select the first provider by default.
  // This helps ensure the model dropdown gets populated.
  if (
    (!selectElement.value || !providerNames.includes(selectElement.value)) &&
    providerNames.length > 0
  ) {
    selectElement.value = providerNames[0];
  }
}

/**
 * Adds a new fallback provider UI section.
 * @param {string} agentKey - The agent key (e.g., 'ai1', 'ai2-executor').
 * @param {HTMLElement} fallbacksContainerElement - The container to add the fallback UI to.
 * @param {string[]} availableProviderNames - List of provider names for the dropdown.
 * @param {object|null} fbConfig - Fallback configuration { provider, model } to pre-fill.
 */
function addFallbackProvider(
  agentKey,
  fallbacksContainerElement,
  availableProviderNames,
  fbConfig = null
) {
  const fallbackId = `fallback-${agentKey}-${Date.now()}-${Math.random()
    .toString(36)
    .substring(2, 7)}`;
  const fallbackDiv = document.createElement("div");
  fallbackDiv.className = "fallback-provider-item";
  fallbackDiv.id = fallbackId;
  fallbackDiv.style.marginTop = "5px";
  fallbackDiv.style.padding = "5px";
  fallbackDiv.style.border = "1px dashed #ccc";

  const providerSelect = document.createElement("select");
  providerSelect.className = "fallback-provider-select";
  populateProviderDropdown(
    providerSelect,
    availableProviderNames,
    fbConfig ? fbConfig.provider : null
  );

  const modelSelect = document.createElement("select");
  modelSelect.className = "fallback-model-select";

  if (fbConfig && fbConfig.provider) {
    fetchProviderModels(fbConfig.provider, modelSelect, fbConfig.model);
  } else if (providerSelect.value) {
    // If a provider is selected (e.g. first from the list)
    fetchProviderModels(providerSelect.value, modelSelect, null);
  }

  providerSelect.addEventListener("change", () => {
    fetchProviderModels(providerSelect.value, modelSelect, null); // Select default/first model
  });

  const removeButton = document.createElement("button");
  removeButton.textContent = "Remove Fallback";
  removeButton.className = "remove-fallback-button";
  removeButton.style.marginLeft = "10px";
  removeButton.onclick = () => {
    fallbackDiv.remove();
    // Optionally, trigger a save or update state
  };

  fallbackDiv.appendChild(document.createTextNode("Fallback Provider: "));
  fallbackDiv.appendChild(providerSelect);
  fallbackDiv.appendChild(document.createTextNode(" Model: "));
  fallbackDiv.appendChild(modelSelect);
  fallbackDiv.appendChild(removeButton);
  fallbacksContainerElement.appendChild(fallbackDiv);
}

/**
 * Sets up the UI for a specific AI agent/component based on config.
 * @param {string} agentKeyPrefix - Prefix for element IDs (e.g., 'ai1', 'ai2-executor').
 * @param {object} agentData - Config data for the agent { provider, model, fallbacks }.
 * @param {string[]} globalAvailableProviderNames - Global list of provider names.
 * @param {string[]|null} specificAvailableProviderNames - Agent-specific list of provider names.
 */
function setupAgentUI(
  agentKeyPrefix,
  agentData,
  globalAvailableProviderNames,
  specificAvailableProviderNames = null
) {
  const providerSelect = document.getElementById(
    `${agentKeyPrefix}-provider-select`
  );
  const modelSelect = document.getElementById(`${agentKeyPrefix}-model-select`);
  const fallbacksContainer = document.getElementById(
    `${agentKeyPrefix}-fallbacks-container`
  );
  // Assuming button ID follows a pattern like 'add-fallback-ai1' or uses dataset attributes for a generic handler.
  // For simplicity, let's assume a specific button per agent section.
  const addFallbackButton = document.getElementById(
    `add-fallback-${agentKeyPrefix}`
  );

  if (!providerSelect || !modelSelect || !fallbacksContainer) {
    console.warn(
      `UI elements for ${agentKeyPrefix} not found. Provider: ${providerSelect}, Model: ${modelSelect}, Fallbacks: ${fallbacksContainer}`
    );
    return;
  }

  const providersToUse =
    specificAvailableProviderNames && specificAvailableProviderNames.length > 0
      ? specificAvailableProviderNames
      : globalAvailableProviderNames;

  populateProviderDropdown(providerSelect, providersToUse, agentData.provider);
  // Ensure fetchProviderModels is called after populateProviderDropdown might have changed providerSelect.value
  fetchProviderModels(providerSelect.value, modelSelect, agentData.model);

  providerSelect.addEventListener("change", () => {
    fetchProviderModels(providerSelect.value, modelSelect, null); // Select default/first model
  });

  // Clear existing fallbacks
  fallbacksContainer.innerHTML = "";

  // Add fallbacks from config
  if (agentData.fallbacks && Array.isArray(agentData.fallbacks)) {
    agentData.fallbacks.forEach((fb) => {
      addFallbackProvider(
        agentKeyPrefix,
        fallbacksContainer,
        providersToUse,
        fb
      );
    });
  }

  // Setup "Add Fallback" button for this agent
  if (addFallbackButton) {
    addFallbackButton.onclick = (event) => {
      // Using onclick for simplicity, consider addEventListener for robust apps
      event.preventDefault();
      addFallbackProvider(
        agentKeyPrefix,
        fallbacksContainer,
        providersToUse,
        null
      );
    };
  } else {
    console.warn(
      `Add fallback button for ${agentKeyPrefix} (e.g., #add-fallback-${agentKeyPrefix}) not found.`
    );
  }
}

/**
 * Initializes the provider configuration UI based on window.currentConfig.
 */
function initProviderConfig() {
  if (
    !window.currentConfig ||
    !window.currentConfig.ai_config ||
    !window.currentConfig.providers
  ) {
    console.error(
      "Current config (window.currentConfig), ai_config, or providers not found on window object. Cannot initialize provider UI."
    );
    return;
  }
  const aiConfig = window.currentConfig.ai_config;
  const globalAvailableProviderNames = Object.keys(
    window.currentConfig.providers
  );

  // Store full provider details if fetchProviderModels or other functions need it.
  // window.availableProvidersDetails = window.currentConfig.providers; // If needed elsewhere

  // AI1
  if (aiConfig.ai1) {
    const agentData = {
      provider: aiConfig.ai1.provider,
      model: aiConfig.ai1.model,
      fallbacks: aiConfig.ai1.fallbacks || [],
    };
    const specificProviders =
      aiConfig.ai1.providers && Array.isArray(aiConfig.ai1.providers)
        ? aiConfig.ai1.providers
        : null;
    setupAgentUI(
      "ai1",
      agentData,
      globalAvailableProviderNames,
      specificProviders
    );
  }

  // AI2 Roles
  if (aiConfig.ai2) {
    const roles = ["executor", "tester", "documenter"];
    roles.forEach((role) => {
      if (aiConfig.ai2[role]) {
        const roleConfig = aiConfig.ai2[role];
        const agentData = {
          provider: roleConfig.provider,
          model: roleConfig.model,
          fallbacks: roleConfig.fallbacks || [],
        };
        let specificProviders = null;
        if (
          aiConfig.ai2.providers &&
          aiConfig.ai2.providers[role] &&
          Array.isArray(aiConfig.ai2.providers[role])
        ) {
          specificProviders = aiConfig.ai2.providers[role];
        }
        setupAgentUI(
          `ai2-${role}`,
          agentData,
          globalAvailableProviderNames,
          specificProviders
        );
      }
    });
  }

  // AI3
  if (aiConfig.ai3) {
    // AI3 Main
    const ai3MainAgentData = {
      provider: aiConfig.ai3.provider,
      model: aiConfig.ai3.model,
      fallbacks: aiConfig.ai3.fallbacks || [],
    };
    const ai3MainSpecificProviders =
      aiConfig.ai3.providers && Array.isArray(aiConfig.ai3.providers)
        ? aiConfig.ai3.providers
        : null;
    setupAgentUI(
      "ai3-main",
      ai3MainAgentData,
      globalAvailableProviderNames,
      ai3MainSpecificProviders
    );

    // AI3 Structure
    if (
      aiConfig.ai3.structure_provider &&
      aiConfig.ai3.structure_model !== undefined
    ) {
      // Check for structure-specific config
      const ai3StructureAgentData = {
        provider: aiConfig.ai3.structure_provider,
        model: aiConfig.ai3.structure_model,
        fallbacks: aiConfig.ai3.structure_fallbacks || [],
      };
      const ai3StructureSpecificProviders =
        aiConfig.ai3.structure_providers &&
        Array.isArray(aiConfig.ai3.structure_providers)
          ? aiConfig.ai3.structure_providers
          : null;
      setupAgentUI(
        "ai3-structure",
        ai3StructureAgentData,
        globalAvailableProviderNames,
        ai3StructureSpecificProviders
      );
    }
  }
  console.log("Provider configuration UI initialized.");
}

