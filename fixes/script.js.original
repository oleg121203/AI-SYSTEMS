  ) {
    const list = document.querySelector("#ai2-tester-fallback-list");
    aiConfig.ai2.tester.fallbacks.forEach(async (fallback, idx) => {
      await addConfiguredFallback("ai2-tester", list, fallback, idx);
    });
  }
  // AI2 Documenter
  if (
    aiConfig.ai2 &&
    aiConfig.ai2.documenter &&
    aiConfig.ai2.documenter.fallbacks &&
    aiConfig.ai2.documenter.fallbacks.length > 0
  ) {
    const list = document.querySelector("#ai2-documenter-fallback-list");
    aiConfig.ai2.documenter.fallbacks.forEach(async (fallback, idx) => {
      await addConfiguredFallback("ai2-documenter", list, fallback, idx);
    });
  }
  // AI3
  if (
    aiConfig.ai3 &&
    aiConfig.ai3.fallbacks &&
    aiConfig.ai3.fallbacks.length > 0
  ) {
    const list = document.querySelector("#ai3-fallback-list");
    aiConfig.ai3.fallbacks.forEach(async (fallback, idx) => {
      await addConfiguredFallback("ai3", list, fallback, idx);
    });
  }
  // AI3 Structure
  if (
    aiConfig.ai3 &&
    aiConfig.ai3.structure_fallbacks &&
    aiConfig.ai3.structure_fallbacks.length > 0
  ) {
    const list = document.querySelector("#ai3-structure-fallback-list");
    aiConfig.ai3.structure_fallbacks.forEach(async (fallback, idx) => {
      await addConfiguredFallback("ai3-structure", list, fallback, idx);
    });
