/**
 * Sets up the UI for a specific AI agent/component based on config.
 * @param {string} agentKeyPrefix - Prefix for element IDs (e.g., 'ai1', 'ai2-executor').
 * @param {object} agentData - Config data for the agent { provider, model, fallbacks }.
 * @param {string[]} globalAvailableProviderNames - Global list of provider names.
 * @param {string[]|null} specificAvailableProviderNames - Agent-specific list of provider names.
 */
function setupAgentUI(
  agentKeyPrefix,
  agentData, // { provider, model, fallbacks }
  globalAvailableProviderNames,
  specificAvailableProviderNames = null
) {
  const providerSelect = document.getElementById(
    `${agentKeyPrefix}-provider-select`
  );
  const modelSelect = document.getElementById(`${agentKeyPrefix}-model-select`);
  const fallbacksContainer = document.getElementById(
    `${agentKeyPrefix}-fallbacks-container`
  );
  const addFallbackButton = document.getElementById(
    `add-fallback-${agentKeyPrefix}`
  );

  if (!providerSelect || !modelSelect || !fallbacksContainer) {
    console.warn(
      `UI elements for ${agentKeyPrefix} not found. Provider: ${!!providerSelect}, Model: ${!!modelSelect}, FallbacksContainer: ${!!fallbacksContainer}. Skipping setup.`
    );
    return;
  }

  // 1. Determine the base list of providers for this agent
  // This list is used for populating dropdowns for NEW fallbacks.
  let baseProvidersForAgent = [...globalAvailableProviderNames]; // Start with a mutable copy of global
  if (
    specificAvailableProviderNames &&
    specificAvailableProviderNames.length > 0
  ) {
    baseProvidersForAgent = [...specificAvailableProviderNames]; // Use specific if available, mutable copy
  }

  // 2. For the main provider dropdown, ensure the configured agentData.provider is an option
  let mainProviderDropdownOptions = [...baseProvidersForAgent]; // Start with a copy of the base list
  if (
    agentData.provider &&
    !mainProviderDropdownOptions.includes(agentData.provider)
  ) {
    mainProviderDropdownOptions.push(agentData.provider);
    console.warn(
      `Agent ${agentKeyPrefix}: Main provider '${
        agentData.provider
      }' was not in its specific list [${baseProvidersForAgent.join(", ")}]. ` +
        `Added it to its dropdown. Ensure '${agentData.provider}' is defined in global providers config for full functionality.`
    );
  }
  populateProviderDropdown(
    providerSelect,
    mainProviderDropdownOptions,
    agentData.provider
  );

  // 3. Fetch models for the (now correctly) selected main provider
  if (providerSelect.value) {
    fetchProviderModels(providerSelect.value, modelSelect, agentData.model);
  } else if (mainProviderDropdownOptions.length > 0) {
    // If agentData.provider was empty or not in list, and list is not empty, populateProviderDropdown might select the first.
    // Or, if mainProviderDropdownOptions was initially empty and then agentData.provider was pushed.
    providerSelect.value = mainProviderDropdownOptions[0]; // Explicitly select the first if none selected
    fetchProviderModels(providerSelect.value, modelSelect, agentData.model); // Try fetching with current agentData.model
  } else {
    modelSelect.innerHTML = '<option value="">No providers available</option>';
  }

  // 4. Event listener for main provider change
  providerSelect.addEventListener("change", () => {
    if (providerSelect.value) {
      fetchProviderModels(providerSelect.value, modelSelect, null); // Fetch models, select first/default
    } else {
      modelSelect.innerHTML = '<option value="">Select a provider</option>';
    }
  });

  // 5. Setup fallbacks
  fallbacksContainer.innerHTML = ""; // Clear existing fallbacks UI

  if (agentData.fallbacks && Array.isArray(agentData.fallbacks)) {
    agentData.fallbacks.forEach((fbConfig) => {
      // For each existing fallback, its dropdown should also contain its configured provider
      let fallbackDropdownOptions = [...baseProvidersForAgent]; // Start with agent's base list
      if (
        fbConfig.provider &&
        !fallbackDropdownOptions.includes(fbConfig.provider)
      ) {
        fallbackDropdownOptions.push(fbConfig.provider);
        console.warn(
          `Agent ${agentKeyPrefix}, Fallback: Provider '${fbConfig.provider}' added to its dropdown options as it was not in the agent's base list.`
        );
      }
      addFallbackProvider(
        agentKeyPrefix,
        fallbacksContainer,
        fallbackDropdownOptions,
        fbConfig
      );
    });
  }

  // 6. Setup "Add Fallback" button
  if (addFallbackButton) {
    addFallbackButton.onclick = (event) => {
      event.preventDefault();
      // When adding a NEW fallback, use the agent's base provider list.
      addFallbackProvider(
        agentKeyPrefix,
        fallbacksContainer,
        baseProvidersForAgent, // Use the agent's base list for new fallbacks
        null // No pre-filled config
      );
    };
  } else {
    console.warn(
      `Add fallback button #add-fallback-${agentKeyPrefix} not found.`
    );
  }
}

