  ) {
    const list = document.querySelector("#ai1-fallback-list");
    aiConfig.ai1.fallbacks.forEach(async (fallback, idx) => {
      await addConfiguredFallback("ai1", list, fallback, idx);
    });
  }
  // AI2 Executor
  if (
    aiConfig.ai2 &&
    aiConfig.ai2.executor &&
    aiConfig.ai2.executor.fallbacks &&
    aiConfig.ai2.executor.fallbacks.length > 0
  ) {
    const list = document.querySelector("#ai2-executor-fallback-list");
    aiConfig.ai2.executor.fallbacks.forEach(async (fallback, idx) => {
      await addConfiguredFallback("ai2-executor", list, fallback, idx);
    });
  }
  // AI2 Tester
  if (
    aiConfig.ai2 &&
    aiConfig.ai2.tester &&
